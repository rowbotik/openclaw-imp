OPENAI_API_KEY=
OPENCLAW_TOKEN=
OPENCLAW_BASE_URL=https://gateway-host.tailnet-name.ts.net
OPENCLAW_MODEL=openclaw/daemon
OPENCLAW_RESPONSE_STYLE=Imp Zero is speaking between the user and Daemon. Reply in third person as Daemon, for example: Daemon says he will take care of that. Keep replies short and spoken-friendly.

# Imp Zero defaults
ENABLE_TTS=true
TTS_THIRD_PERSON=true
TTS_PROVIDER=openai
AUDIO_DEVICE=plughw:1,0
AUDIO_OUTPUT_DEVICE=plughw:1,0
AUDIO_OUTPUT_CARD=1
SPEAKER_VOLUME=55

# Optional tuning
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts-2025-12-15
OPENAI_TTS_VOICE=coral
OPENAI_TTS_SPEED=1.1
OPENAI_TTS_GAIN_DB=0
TTS_BASS_DB=4
TTS_TREBLE_DB=-3
TTS_NORM_DB=-3
LCD_BACKLIGHT=70
UI_MAX_FPS=8
DISPLAY_SLEEP_TIMEOUT=0
IMP_IDLE_MOOD=happy
IMP_BODY_COLOR=yellow
IMP_ACCESSORY_MODE=random
IMP_FLOAT_PIXELS=3
IMP_SHADOW=true
IMP_BACKGROUND=circuit
IMP_BACKGROUND_BRIGHTNESS=45
ENABLE_LED=true
LED_IDLE_BRIGHTNESS=0
SILENCE_RMS_THRESHOLD=200

# Optional ElevenLabs TTS. Keep OPENAI_API_KEY for transcription.
# TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=your-elevenlabs-api-key
# ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# ELEVENLABS_OUTPUT_FORMAT=pcm_24000
