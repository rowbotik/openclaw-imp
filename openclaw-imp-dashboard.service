[Unit]
Description=Imp Zero LAN Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/openclaw-imp
Environment=IMP_DASHBOARD_HOST=0.0.0.0
Environment=IMP_DASHBOARD_PORT=8080
Environment=IMP_SERVICE_NAME=openclaw-imp.service
ExecStart=/usr/bin/python3 dashboard.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
